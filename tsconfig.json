{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "node",
      "vitest/globals",
      "chrome",
      "webextension-polyfill"
    ],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    ".wxt/wxt.d.ts",
    "src",
    "entrypoints",
    "tests",
    "wxt.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "src/vite-env.d.ts"
  ]
}
